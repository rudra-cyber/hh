rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerifiedUser() {
      return isSignedIn(); // Support Google logins
    }

    // Rules for Trade Journal Entry
    match /trades/{tradeId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(tradeId) && isValidTrade(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(tradeId) && isValidTrade(incoming()) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Validation helper for Trade
    function isValidTrade(data) {
      return data.keys().hasAll(['id', 'userId', 'pair', 'strategy', 'direction', 'time', 'profit'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.pair is string && data.pair.size() <= 32
        && data.strategy is string && data.strategy.size() <= 128
        && data.direction is string && (data.direction == 'LONG' || data.direction == 'SHORT')
        && data.time is string && data.time.size() <= 64
        && (data.profit is int || data.profit is float || data.profit is number)
        && (!data.keys().hasAny(['riskReward']) || (data.riskReward is int || data.riskReward is float || data.riskReward is number))
        && (!data.keys().hasAny(['mistake']) || (data.mistake is string && data.mistake.size() <= 256))
        && (!data.keys().hasAny(['entryReason']) || (data.entryReason is string && data.entryReason.size() <= 4096))
        && (!data.keys().hasAny(['images']) || (data.images is list && data.images.size() <= 20))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 64));
    }

    // Rules for Strategies
    match /strategies/{strategyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(strategyId) && isValidStrategy(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(strategyId) && isValidStrategy(incoming()) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Validation helper for Strategy
    function isValidStrategy(data) {
      return data.keys().hasAll(['id', 'userId', 'name'])
        && data.keys().size() <= 6
        && data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() <= 128
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 2048))
        && (!data.keys().hasAny(['createdAt']) || (data.createdAt is string && data.createdAt.size() <= 64));
    }
  }
}
